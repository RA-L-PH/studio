rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clinics/{userId} {
      // Allow public read of clinic data for searching and viewing
      allow read: if true;

      // A user can create a clinic document for their own UID
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.clinicCode != null;

      // Only the owner can update or delete their clinic document
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // This collection is used to enforce unique clinic codes
    match /clinic_codes/{clinicCode} {
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
}
