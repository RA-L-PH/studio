
{
  "entities": {
    "QueueItem": {
      "title": "Queue Item",
      "description": "A patient in the clinic queue (RTDB).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "token_number": { "type": "number" },
        "status": { "type": "string", "enum": ["waiting", "active", "completed", "no-show"] },
        "created_at": { "type": "number" },
        "called_at": { "type": "number" },
        "completed_at": { "type": "number" }
      },
      "required": ["name", "token_number", "status", "created_at"]
    },
    "ClinicStats": {
      "title": "Clinic Statistics",
      "description": "Global metrics for the clinic flow (RTDB).",
      "type": "object",
      "properties": {
        "avg_consult_duration": { "type": "number", "description": "Average duration in ms" },
        "total_patients_today": { "type": "number" }
      }
    },
    "LiveStatus": {
      "title": "Live Status",
      "description": "Ultra-fast synchronization for currently serving patient (RTDB).",
      "type": "object",
      "properties": {
        "token": { "type": "number" },
        "name": { "type": "string" },
        "room": { "type": "string" },
        "updated_at": { "type": "number" }
      }
    }
  },
  "realtime_db": {
    "/queues": {
      "schema": "QueueItem",
      "description": "All patient queue data."
    },
    "/metrics": {
      "schema": "ClinicStats",
      "description": "Clinic analytics."
    },
    "/live_status": {
      "schema": "LiveStatus",
      "description": "The 'Now Serving' ticker."
    }
  }
}
